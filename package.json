{
  "name": "starter-kit",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend/*",
    "apps/backend/*",
    "packages/frontend/*",
    "packages/backend/*",
    "packages/shared/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.51.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md}": [
      "bun format:fix",
      "bun lint:fix"
    ]
  },
  "engines": {
    "bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
