{
  "name": "@tamtt-labs/ddd",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run build -- --watch",
    "build": "bun --bun tsdown --tsconfig tsconfig.build.json",
