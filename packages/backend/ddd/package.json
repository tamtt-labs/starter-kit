    "test": "bun test"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "fast-deep-equal": "^3.1.3"
  },
  "devDependencies": {
    "@tamtt-labs/tsconfig": "workspace:*",
    "@tamtt-labs/tsdown": "workspace:*",
    "@types/bun": "^1.3.10",
    "tsdown": "^0.20.2",
    "typescript": "^5.9.3"
  }
}
